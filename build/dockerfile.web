FROM node:26-alpine AS prepare
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN npm install -g pnpm@11.1.2
WORKDIR /build
ADD package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc tsconfig.base.json tsconfig.node.json ./

FROM prepare AS installed
ADD ./web_dto/package.json ./web_dto/package.json
ADD ./web/package.json ./web/package.json
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile


FROM installed AS build

ADD ./web_dto/tsconfig.json ./web_dto/
ADD ./web_dto/src ./web_dto/src
RUN pnpm run --filter=@ijia/api-types build

ADD ./web/src ./web/src
ADD ./web/public ./web/public
ADD ./web/build ./web/build
ADD ./web/index.html ./web/ssr.html ./web/vite.config.ts ./web/tsconfig.json ./web/

RUN pnpm run --filter=@ijia/web build


FROM nginx:1.26-alpine
WORKDIR /serve/web
ADD ./build/nginx/nginx.conf /etc/nginx/nginx.conf
ADD ./build/nginx/conf.d /etc/nginx/conf.d

ADD ./build/nginx/localhost.crt /tls.crt
ADD ./build/nginx/localhost.key /tls.key

COPY --from=build /build/web/dist/client .
EXPOSE 443

