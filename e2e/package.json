{
  "type": "module",
  "scripts": {
    "e2e:local": "playwright test --ui",
    "check-type": "tsgo --noEmit",
    "install-browsers": "pnpm dlx playwright install chromium webkit firefox",
    "install-browser": "pnpm dlx @puppeteer/browsers install chrome@109",
    "e2e:ci": "playwright test -c playwright.ci.config.ts --trace retain-on-first-failure --retries=1",
    "e2e:bench": "playwright test -c playwright.bench.config.ts",
    "codegen": "playwright codegen --channel msedge",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@asla/hofetch": "jsr:@asla/hofetch@^0.0.1",
    "@asla/pg": "catalog:",
    "@asla/yoursql": "catalog:",
    "@ijia/data": "workspace:^",
    "@playwright/test": "^1.55.0",
    "@types/node": "catalog:",
    "evlib": "catalog:"
  }
}
