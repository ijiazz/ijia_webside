{
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npm.org"
  },
  "scripts": {
    "init-deps": "pnpm run init-ijia-data && pnpm run init-api-types",
    "init-api-types": "pnpm run --filter @ijia/api-types build",
    "init-ijia-data": "tsgo -p deps/ijia-data/tsconfig.json",
    "check-type": "pnpm run -r check-type",
    "check-fmt": "oxfmt --check web_api web e2e",
    "fmt": "oxfmt web_api web e2e"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "oxfmt": "^0.40.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "vitest": "^4.1.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.0.0",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.27.0"
}
